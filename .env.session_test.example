# Salin menjadi .env.session_test hanya bila kredensial lokal berbeda.
# File .env.session_test diabaikan Git dan hanya dipakai launcher session test.

IDP_SESSION_TEST_DB_NAME=logistic_parser_session_test
IDP_SESSION_TEST_ADMIN_DB=postgres

# Opsional: gunakan URL admin khusus. Jangan arahkan ke DB produksi jarak jauh.
# IDP_SESSION_TEST_ADMIN_URL=postgresql+psycopg2://postgres:password@localhost:5432/postgres

# Alternatif kredensial lokal jika IDP_SESSION_TEST_ADMIN_URL tidak digunakan.
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=password
